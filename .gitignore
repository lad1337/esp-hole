# ESP-IDF build artifacts
/build/
/build.esp32p4/
/sdkconfig
/sdkconfig.esp32p4
/sdkconfig.old
/sdkconfig.esp32p4.old
/managed_components/

# Machine-specific EIM install manifest (absolute local paths) — see README
# for how to install ESP-IDF v6.x yourself.
/eim_config.toml

# Machine-specific sdkconfig overrides (e.g. your LAN IP for the manifest
# URL) layered on top of sdkconfig.defaults.esp32p4 — see Makefile.
/sdkconfig.local.esp32p4

# Go build artifacts
/generator/generator
/generator/data/

# Personal/local generator config (machine-specific IP, not for commit)
/generator/config.json
