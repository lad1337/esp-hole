# ESP-IDF build artifacts (sinkhole firmware)
/build/
/sdkconfig
/sdkconfig.old
/managed_components/

# ESP-IDF build artifacts (generator-node firmware)
/generator-node/build/
/generator-node/sdkconfig
/generator-node/sdkconfig.old
/generator-node/managed_components/

# Machine-specific EIM install manifest (absolute local paths) — see README
# for how to install ESP-IDF v6.x yourself.
/eim_config.toml

# Machine-specific sdkconfig overrides (e.g. your LAN IP for the manifest
# URL) layered on top of sdkconfig.defaults — see Makefile.
/sdkconfig.local
/generator-node/sdkconfig.local

# Go build artifacts
/generator/generator
/generator/data/

# Personal/local generator config (machine-specific IP, not for commit)
/generator/config.json

# blocklist_pipeline host test harness build artifacts + downloaded scale-test data
/generator-node/components/blocklist_pipeline/test/host_test
/generator-node/components/blocklist_pipeline/test/scale_test
/generator-node/components/blocklist_pipeline/test/data/
