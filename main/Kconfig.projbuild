menu "DNS sinkhole"

    comment "RMII wiring — set these to match your board"
    comment "(defaults are LAN8720 on plain ESP32 / onboard IP101 on the ESP32-P4-Function-EV-Board)"

    config SINKHOLE_ETH_MDC_GPIO
        int "RMII MDC GPIO"
        range 0 56
        default 31 if IDF_TARGET_ESP32P4
        default 23

    config SINKHOLE_ETH_MDIO_GPIO
        int "RMII MDIO GPIO"
        range 0 56
        default 52 if IDF_TARGET_ESP32P4
        default 18

    config SINKHOLE_ETH_PHY_ADDR
        int "PHY address"
        range 0 31
        default 1

    config SINKHOLE_ETH_PHY_RST_GPIO
        int "PHY reset GPIO (-1 if not wired)"
        range -1 56
        default 51 if IDF_TARGET_ESP32P4
        default -1

    config SINKHOLE_ETH_PHY_POWER_GPIO
        int "PHY power / oscillator-enable GPIO (-1 if not wired)"
        range -1 56
        default -1
        help
            Some boards gate the PHY's power or 50 MHz oscillator behind a
            GPIO (e.g. GPIO16 on WT32-ETH01-style wiring). Set it here so it
            is driven high before the Ethernet driver probes the PHY. Not
            needed on the ESP32-P4-Function-EV-Board (onboard IP101 doesn't
            gate power this way).

    comment "List updates"

    config SINKHOLE_MANIFEST_URL
        string "Blocklist manifest URL"
        default "http://esphole.local:8080/manifest.json"
        help
            Where the generator serves manifest.json. The blocklist blob
            itself is fetched from the manifest's "url" field, so this is
            the only address the updater needs.

    comment "Monitoring (UDP stats reports to the generator)"

    config SINKHOLE_STATS_ENABLE
        bool "Report query stats to a monitoring server"
        default y
        help
            Best-effort monitoring: a low-priority task sends one UDP
            datagram (InfluxDB line protocol) every interval with query
            counts and latency histogram deltas. Send failures are dropped
            silently — this can never affect DNS serving. Disable to compile
            the stats module out entirely.

    config SINKHOLE_STATS_HOST
        string "Stats server host"
        depends on SINKHOLE_STATS_ENABLE
        default "esphole.local"
        help
            Hostname or IPv4 literal of the generator server (its
            stats_listen UDP port). An IP literal avoids depending on LAN
            DNS to resolve .local names.

    config SINKHOLE_STATS_PORT
        int "Stats server UDP port"
        depends on SINKHOLE_STATS_ENABLE
        range 1 65535
        default 8094

    config SINKHOLE_STATS_INTERVAL_S
        int "Stats send interval (seconds)"
        depends on SINKHOLE_STATS_ENABLE
        range 1 3600
        default 10

endmenu
